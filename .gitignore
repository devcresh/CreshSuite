# Windows
Thumbs.db
Desktop.ini
desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Temporary and editor files
*.tmp
*.temp
*.bak
*.old
*.log
*.swp
*.swo
*~
\#*\#
.\#*

# Editor settings (local only)
.vscode/*.local.*
.idea/
.agents/

# Local AI configuration
CLAUDE.local.md
.claude/settings.local.json

# Local development and agent logs (keep the folder documentation)
Logs/*
!Logs/README.md

# Release packages and generated build artifacts
*.zip
*.rar
*.7z
_staging_/
release/build_stats.txt

# WoW runtime files that must never be committed
WTF/
SavedVariables/
*.lua.old

# Python / Node caches
__pycache__/
*.pyc
node_modules/

# Quarantined accidental files (content preserved locally, not in git)
quarantine/prompt_fragments/*
!quarantine/prompt_fragments/README.txt

# Accidental shell-script fragments captured as filenames
Docs/Guides/commit

# Miscellaneous
*.lock
